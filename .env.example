# InventoPC — Variáveis de Ambiente
# Renomeie este arquivo para .env e preencha os valores
# No Windows: SET SUPABASE_URL=... antes de rodar python server.py

# ─── SEGURANÇA ────────────────────────────────────────────────
INVENTOPC_KEY=inventopc-chave-secreta
SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# ─── SUPABASE ─────────────────────────────────────────────────
# Obtenha em: https://supabase.com → Seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── TWILIO ───────────────────────────────────────────────────
# Obtenha em: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número Twilio remetente (SMS: +5511999999999 | WhatsApp: whatsapp:+14155238886)
TWILIO_FROM=+5511999999999

# Número da equipe de TI que recebe notificações
TWILIO_NOTIFY_TO=+5511888888888

# ─── SERVIDOR ─────────────────────────────────────────────────
PORT=5000
